# =============================================================================
# GBM Jobhunter — Production Environment Template
# Safe to commit: all secrets are blank.
# On the VPS: copy this to .env and fill in the blank values.
# =============================================================================

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=gbmjobhunter
POSTGRES_USER=gbmuser
POSTGRES_PASSWORD=

# ── App-wide ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# Must be identical across all services. Generate with: openssl rand -hex 64
JWT_SECRET=

# ── Gateway ───────────────────────────────────────────────────────────────────
# Your domain, e.g. https://gbmjobhunter.com — no trailing slash.
ALLOWED_ORIGINS=

# ── Tier 2 (Groq) ─────────────────────────────────────────────────────────────
TIER2_API_BASE=https://api.groq.com/openai/v1
TIER2_API_KEY=
TIER2_MODEL_NAME=llama-3.3-70b-versatile

# ── Tier 3 (Claude) ───────────────────────────────────────────────────────────
TIER3_API_KEY=
TIER3_MODEL=claude-haiku-4-5-20251001
TIER3_QUOTA_PER_DAY=50
MODEL_TIMEOUT_MS=30000

# ── Intelligence service ───────────────────────────────────────────────────────
# Optional — leave blank to disable push notifications.
FCM_SERVER_KEY=
