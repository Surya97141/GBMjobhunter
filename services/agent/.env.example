PORT=3005
NODE_ENV=development
DATABASE_URL=postgresql://user:pass@localhost:5433/dbname
REDIS_URL=redis://localhost:6380
JWT_SECRET=your_jwt_secret_here

# Tier 2 — OpenAI-compatible inference endpoint (e.g. Groq, Together AI, Fireworks)
TIER2_API_BASE=https://api.groq.com/openai/v1
TIER2_API_KEY=
TIER2_MODEL_NAME=llama3-8b-8192

# Tier 3 — Anthropic (frontier model)
TIER3_API_KEY=
TIER3_MODEL=claude-sonnet-4-6

# Optional overrides
TIER3_QUOTA_PER_DAY=5
MODEL_TIMEOUT_MS=10000
