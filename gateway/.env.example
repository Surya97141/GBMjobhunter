PORT=3000
JWT_SECRET=
NODE_ENV=development
USER_SERVICE_URL=http://127.0.0.1:3001
JOBS_SERVICE_URL=http://127.0.0.1:3002
OPPORTUNITY_SERVICE_URL=http://127.0.0.1:3003
AGENT_SERVICE_URL=http://127.0.0.1:3005
REDIS_URL=redis://127.0.0.1:6380

# Production: set to the deployed Railway URL of the agent service, e.g.
# AGENT_SERVICE_URL=https://gbm-agent.railway.internal

# Comma-separated list of allowed CORS origins.
# Dev default (when unset): http://localhost:5173 only.
# Production: set to the deployed frontend URL, e.g.
# ALLOWED_ORIGINS=https://gbm-web.up.railway.app
ALLOWED_ORIGINS=
