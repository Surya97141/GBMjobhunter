# Replace your-domain.com with your actual domain before starting Caddy.
# DNS A record must point to this VPS IP first — Caddy obtains TLS automatically.

your-domain.com {

    # Proxy /api/* to the gateway, stripping the /api prefix.
    # Gateway routes have no /api prefix (e.g. /auth/login, /users/me).
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy localhost:3000
    }

    # Serve the built React frontend. Fallback to index.html for client-side
    # routing (React Router handles /dashboard, /profile, etc.).
    handle {
        root * /var/www/gbm/web/dist
        try_files {path} /index.html
        file_server
    }
}
